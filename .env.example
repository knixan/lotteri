# Copy to .env.local. Values below work as-is against the local emulator
# suite (npm run emulators) — no real Firebase project needed for that.
#
# "demo-" project ids are special-cased by the emulator suite: it will
# refuse to talk to production, so it's a safe default while learning.
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-mjolby-idrottslotteri.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-mjolby-idrottslotteri
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-mjolby-idrottslotteri.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# --- Only needed once you connect a real Firebase project (deploying) ---
# Get these from a service account key in Firebase Console > Project
# settings > Service accounts > Generate new private key.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
